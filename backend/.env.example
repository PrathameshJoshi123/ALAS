# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/te_platform
DATABASE_ECHO=false

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# JWT Configuration
SECRET_KEY=your-secret-key-min-32-characters-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# AES-256 Encryption (MUST be base64 encoded)
# Generate key: openssl enc -aes-256-cbc -P -S <salt> -pass pass:<password> -nosalt, copy salt value
# Then base64 encode
AES_KEY=your-base64-encoded-32-byte-key
AES_IV=your-base64-encoded-16-byte-iv

# Application Configuration
APP_NAME=TE Legal Platform
APP_VERSION=0.1.0
DEBUG=false

# CORS Configuration
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Audit Configuration
ENABLE_AUDIT_LOGGING=true
AUDIT_RETENTION_DAYS=365

# Bcrypt Configuration
BCRYPT_ROUNDS=12

# ==================== CONTRACT SERVICE ====================
# Mistral API Configuration
MISTRAL_API_KEY=your-mistral-api-key-here
MISTRAL_MODEL_CHAT=mistral-medium
MISTRAL_MODEL_EMBEDDINGS=mistral-embed
MISTRAL_EMBEDDING_DIMENSION=1536
MISTRAL_API_TIMEOUT=60

# ChromaDB Configuration
CHROMADB_PATH=./chromadb_data
CHROMADB_COLLECTION_CLAUSES=contract_clauses
CHROMADB_COLLECTION_PRECEDENTS=precedent_playbook
CHROMADB_COLLECTION_STATUTES=statutory_references

# PaddleOCR Configuration
PADDLE_OCR_MODELS_PATH=./paddle_ocr_models
PADDLE_OCR_USE_GPU=False
PADDLE_OCR_USE_ANGLE_CLS=True
PADDLE_OCR_LANGUAGE=en

# File Upload Settings
UPLOAD_DIR=./files
MAX_UPLOAD_SIZE_MB=50
ALLOWED_FILE_TYPES=.pdf

# Contract Analysis Settings
FEATURE_ASYNC_ANALYSIS=True
FEATURE_PLAYBOOK_MATCHING=True
FEATURE_STATUTORY_CHECKING=True
BATCH_EMBEDDING_SIZE=50
CONTRACT_ANALYSIS_TIMEOUT_SECONDS=600

# DeepAgents Configuration
DEEPAGENTS_SUBAGENT_TIMEOUT=300
DEEPAGENTS_MAX_MEMORY_STEPS=10
DEEPAGENTS_ENABLE_LOGGING=False

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_UPLOAD_PER_DAY=100

# Logging
LOG_LEVEL=INFO
ENABLE_AUDIT_LOGGING=True
AUDIT_LOG_RETENTION_DAYS=90
